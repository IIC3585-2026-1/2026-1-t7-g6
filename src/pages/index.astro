---
import Layout from '../layouts/Layout.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import CryptoFilter from '../components/vue/CryptoFilter.vue';
import RealtimeCrypto from '../components/svelte/RealtimeCrypto.svelte';

const fallbackCryptos = [
  { id: 'bitcoin', name: 'Bitcoin', symbol: 'btc' },
  { id: 'ethereum', name: 'Ethereum', symbol: 'eth' },
  { id: 'solana', name: 'Solana', symbol: 'sol' },
];

let cryptos = fallbackCryptos;
try {
  const response = await fetch("https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=25");
  const data = await response.json();

  if (!response.ok) {
    throw new Error(`CoinGecko respondió con estado ${response.status}`);
  }

  if (!Array.isArray(data)) {
    throw new Error("CoinGecko no devolvió una lista de criptomonedas");
  }

  const validCryptos = data.filter(
    (crypto) => crypto?.id && crypto?.name && crypto?.symbol,
  );

  if (validCryptos.length === 0) {
    throw new Error("CoinGecko devolvió una lista vacía");
  }

  cryptos = validCryptos;
} catch (error) {
  console.error("Error obteniendo datos de la API:", error);
}
---

<Layout>
	<Header />
	<main class="container mx-auto px-4 py-8 grow">
    
    <section class="mb-10 text-center">
      <h2 class="text-3xl font-extrabold text-slate-800 mb-2">Monitoreo del Mercado</h2>
      <p class="text-slate-600">Datos base generados estáticamente. Selecciona una moneda para ver tiempo real.</p>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <aside class="lg:col-span-1 bg-white p-6 rounded-xl shadow-sm border border-slate-100">
        <h3 class="text-lg font-semibold mb-4 border-b pb-2">Configuración</h3>
        <CryptoFilter client:load cryptosList={cryptos} />
      </aside>

      <section class="lg:col-span-2 bg-white p-6 rounded-xl shadow-sm border border-slate-100 min-h-100">
        <h3 class="text-lg font-semibold mb-4 border-b pb-2">Gráfico en Tiempo Real</h3>
				<RealtimeCrypto
					client:visible
					initialCoin={cryptos[0]?.id ?? 'bitcoin'}
				/>
      </section>

    </div>
  </main>
	<Footer />
</Layout>
